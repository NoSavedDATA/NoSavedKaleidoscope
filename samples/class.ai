class Quadrado
    def __init__(f lado)
        self.lado = lado
        0;
        
    def area()
        self.lado * self.lado

    def perimetro()
        self.lado * 4

Quadrado quadrado;
quadrado.__init__(5.0);

quadrado.area();
quadrado.perimetro();